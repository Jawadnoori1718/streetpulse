# Copy this file to frontend/.env and fill in your values

# Google Maps JavaScript API key (required to render the map).
# Get one at https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_KEY=

# If deploying frontend separately from backend, set the full backend URL.
# Leave empty to use the Vite dev proxy (default for local development).
VITE_API_URL=http://localhost:8080
